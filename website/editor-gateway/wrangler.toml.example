[[d1_databases]]
binding = "DB"
database_name = "competitive-programming-editorials"
database_id = "REPLACE_WITH_D1_DATABASE_ID"
migrations_dir = "migrations"

[vars]
OWNER_LOGINS = "smiles0527"
SITE_ORIGIN = "https://smiles0527.github.io"
