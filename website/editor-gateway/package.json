{
  "name": "competitive-programming-editorial-cms",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local",
    "db:migrate": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "seed:build": "node scripts/build-seed.mjs",
    "db:seed": "wrangler d1 execute DB --local --file .wrangler/editorials.sql",
    "db:seed:remote": "wrangler d1 execute DB --remote --file .wrangler/editorials.sql",
    "db:export": "wrangler d1 export DB --remote --output backups/editorials.sql",
    "snapshot:check": "node scripts/check-snapshot.mjs",
    "check": "node --check src/worker.js && node --check scripts/build-seed.mjs && node --check scripts/check-snapshot.mjs && node scripts/check-snapshot.mjs && node --test tests/*.test.mjs",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "wrangler": "^4.26.1"
  }
}
